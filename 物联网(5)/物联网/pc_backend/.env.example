# 后端监听。必须为 0.0.0.0，其他成员才能通过局域网访问。
FOCUSCUBE_HOST=0.0.0.0
FOCUSCUBE_PORT=8000
FOCUSCUBE_DATABASE_PATH=data/focuscube.db
FOCUSCUBE_TIMEZONE=Asia/Shanghai
FOCUSCUBE_CORS_ORIGINS=*

FOCUSCUBE_ACTIVE_DEVICE_ID=focuscube-base-01
FOCUSCUBE_DEFAULT_INSTALLATION_ID=focuscube-base-01

FOCUSCUBE_LLM_PROVIDER=volcengine_ai_gateway

# 以下 3 项必须从 AI Gateway 控制台“查看代码”复制实际值。
# BASE_URL 可以是控制台给出的 OpenAI 兼容 base URL（通常含 /v1），
# 也可以直接填写完整的 /chat/completions 地址。
FOCUSCUBE_LLM_BASE_URL=TODO_控制台实际地址
FOCUSCUBE_LLM_API_KEY=TODO_网关访问密钥
FOCUSCUBE_LLM_MODEL=TODO_实际模型标识
FOCUSCUBE_LLM_TIMEOUT_S=30
